{
  "manifest_version": 3,
  "name": "LinkedIn Shield",
  "version": "3.1.0",
  "description": "Block LinkedIn's hidden extension scanning, device fingerprinting, and tracker probes. Open-source privacy protection.",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.protechts.net/*",
    "*://*.licdn.com/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://*.aliyuncs.com/*",
    "https://api.deepseek.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/shield-16.png",
      "32": "icons/shield-32.png",
      "48": "icons/shield-48.png",
      "128": "icons/shield-128.png"
    }
  },
  "icons": {
    "16": "icons/shield-16.png",
    "32": "icons/shield-32.png",
    "48": "icons/shield-48.png",
    "128": "icons/shield-128.png"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "linkedin_blocklist",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
